DB_HOST=db
DB_PORT=5432
DB_NAME=sala_juntas
DB_USER=ibero
DB_PASSWORD=changeme
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=8h
PORT=3000

# SMTP — leave blank to disable email (app still works without it)
# IMPORTANT: SMTP_FROM must match SMTP_USER exactly — Outlook/Microsoft 365 rejects mismatches
# For Microsoft 365: use an App Password if MFA is enabled (basic auth may be disabled by admin)
# For Gmail: use an App Password (not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@domain.com
APP_URL=http://localhost:8080

# AI assistant — leave AI_API_KEY blank to disable (frontend falls back to local NLP parser)
AI_PROVIDER=anthropic
AI_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001
